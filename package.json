{
  "name": "create-samrose-app",
  "version": "0.1.0",
  "description": "A CLI to scaffold production-ready Next.js apps with your preferred stack",
  "type": "module",
  "bin": {
    "create-samrose-app": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.3.0",
    "execa": "^9.3.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "nextjs",
    "scaffold",
    "starter",
    "create-app",
    "drizzle",
    "prisma",
    "tailwind",
    "shadcn"
  ],
  "license": "MIT"
}
